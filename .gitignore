# ── Floorcast monorepo umbrella .gitignore ──
# Covers the whole repo: root-level artifacts, backend/, and the upcoming
# frontend/. backend/ also keeps its own .gitignore (Python-specific); this is
# the umbrella so patterns apply everywhere.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Seed / scratch output
*.seed.json
scratch/

# Env / secrets
.env
.env.local
*.local
*.local.yaml

# Frontend (Node / Next.js / Vercel) — for the future frontend/
node_modules/
.next/
.vercel/
.turbo/
*.tsbuildinfo

# OS / editor
.DS_Store
.idea/
.vscode/

# AWS SAM / serverless build artifacts
.aws-sam/
.serverless/
