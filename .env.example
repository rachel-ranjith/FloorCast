# ---- Floorcast environment ----
# Copy to .env and fill in. Anything here overrides config/floorcast.yaml
# (env vars are layered on top of the YAML config via pydantic-settings).

FLOORCAST_ENV=local

# ---- AWS / DynamoDB ----
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
# Point at DynamoDB Local for offline dev (leave blank to use real AWS):
DYNAMODB_ENDPOINT_URL=http://localhost:8000
FLOORCAST_DYNAMO__TABLE_NAME=floorcast-local

# ---- Aurora PostgreSQL ----
# Async SQLAlchemy URL. For Aurora Serverless v2 use the cluster writer endpoint.
FLOORCAST_AURORA__DSN=postgresql+psycopg://floorcast:floorcast@localhost:5432/floorcast

# ---- Path to the YAML config file (constraints live here) ----
FLOORCAST_CONFIG_FILE=config/floorcast.yaml
